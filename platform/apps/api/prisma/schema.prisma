generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActorType {
  PLATFORM
  TENANT
  CUSTOMER
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PlatformRole {
  OWNER
  ADMIN
  SUPPORT
  ANALYST
}

enum TenantStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum CustomDomainVerificationState {
  PENDING
  VERIFIED
  FAILED
  DENIED
}

enum CustomDomainPromotionState {
  NOT_REQUESTED
  READY
  PROMOTED
  FAILED
  ROLLBACK_PENDING
  ROLLED_BACK
  DENIED
}

enum CredentialKind {
  PASSWORD
}

enum SessionScope {
  PLATFORM
  TENANT
  CUSTOMER
}

model User {
  id                String               @id @default(uuid())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  email             String               @unique
  normalizedEmail   String               @unique
  displayName       String?
  actorType         ActorType
  status            UserStatus           @default(INVITED)
  platformRole      PlatformRole?
  isEmailVerified   Boolean              @default(false)
  lastAuthenticatedAt DateTime?
  passwordCredential PasswordCredential?
  sessions          AuthSession[]
  memberships       TenantMembership[]

  @@index([actorType, status])
}

model Tenant {
  id               String             @id @default(uuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  displayName      String
  slug             String             @unique
  status           TenantStatus       @default(DRAFT)
  previewSubdomain String             @unique
  customDomainRecords TenantCustomDomain[]
  memberships      TenantMembership[]
  catalogCategories CatalogCategory[]
  catalogItems     CatalogItem[]
  services         Service[]
  staffProfiles    StaffProfile[]
  contentPages     ContentPage[]
  announcements    Announcement[]
  cartSessions     CartSession[]
}

model TenantCustomDomain {
  id                         String                        @id @default(uuid())
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt
  tenantId                   String
  hostname                   String
  verificationState          CustomDomainVerificationState @default(PENDING)
  verificationStateChangedAt DateTime?
  verificationFailureReason  String?
  verificationEvidence       Json?
  promotionState             CustomDomainPromotionState    @default(NOT_REQUESTED)
  promotionStateChangedAt    DateTime?
  promotionFailureReason     String?
  promotedAt                 DateTime?
  rollbackCompletedAt        DateTime?
  tenant                     Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, hostname])
  @@index([hostname])
  @@index([tenantId, verificationState])
  @@index([tenantId, promotionState])
}

model TenantMembership {
  id          String     @id @default(uuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenantId    String
  userId      String
  role        TenantRole
  isPrimary   Boolean    @default(false)
  joinedAt    DateTime   @default(now())
  revokedAt   DateTime?
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, role])
  @@index([tenantId, role])
}

model PasswordCredential {
  id                String         @id @default(uuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  userId            String         @unique
  kind              CredentialKind @default(PASSWORD)
  passwordHash      String
  hashAlgorithm     String
  passwordVersion   Int            @default(1)
  passwordChangedAt DateTime       @default(now())
  mustRotate        Boolean        @default(false)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id                String       @id @default(uuid())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  userId            String
  actorType         ActorType
  scope             SessionScope
  refreshTokenHash  String       @unique
  issuedAt          DateTime     @default(now())
  expiresAt         DateTime
  idleExpiresAt     DateTime
  lastSeenAt        DateTime?
  revokedAt         DateTime?
  revokeReason      String?
  ipAddress         String?
  userAgent         String?
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ─── Epic 6 — Catalog Domain ───────────────────────────────────────────

enum CatalogItemStatus {
  ACTIVE
  INACTIVE
}

enum CatalogItemVisibility {
  PUBLISHED
  DRAFT
}

model CatalogCategory {
  id          String        @id @default(uuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenantId    String
  name        String
  slug        String
  description String?
  imageUrl    String?
  sortOrder   Int           @default(0)
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       CatalogItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, sortOrder])
}

model CatalogItem {
  id              String                @id @default(uuid())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenantId        String
  categoryId      String
  name            String
  slug            String
  description     String?
  price           Int                   // cents
  compareAtPrice  Int?                  // cents — strike-through price
  status          CatalogItemStatus     @default(ACTIVE)
  visibility      CatalogItemVisibility @default(DRAFT)
  sortOrder       Int                   @default(0)
  stockQuantity   Int?
  lowStockThreshold Int?
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        CatalogCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mediaGallery    CatalogItemMedia[]
  modifierGroups  ModifierGroup[]

  @@unique([tenantId, slug])
  @@index([tenantId, categoryId, sortOrder])
  @@index([tenantId, status, visibility])
}

model CatalogItemMedia {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now())
  itemId    String
  url       String
  altText   String?
  sortOrder Int         @default(0)
  item      CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
}

model ModifierGroup {
  id          String            @id @default(uuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenantId    String
  itemId      String
  name        String            // e.g. "Size", "Color", "Add-ons"
  selectionMode String          @default("single") // "single" | "multiple"
  isRequired  Boolean           @default(false)
  minSelections Int             @default(0)
  maxSelections Int?
  sortOrder   Int               @default(0)
  item        CatalogItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options     ModifierOption[]

  @@index([tenantId, itemId, sortOrder])
}

model ModifierOption {
  id           String        @id @default(uuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  groupId      String
  name         String
  priceAdjustment Int        @default(0) // cents, can be 0 or positive
  isDefault    Boolean       @default(false)
  sortOrder    Int           @default(0)
  group        ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, sortOrder])
}

// ─── Epic 6 — Service Domain ───────────────────────────────────────────

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

model Service {
  id                String           @id @default(uuid())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenantId          String
  name              String
  slug              String
  description       String?
  durationMinutes   Int
  price             Int              // cents
  status            ServiceStatus    @default(ACTIVE)
  isBookable        Boolean          @default(true)
  bufferMinutes     Int              @default(0)
  maxAdvanceDays    Int              @default(60)
  minAdvanceHours   Int              @default(1)
  sortOrder         Int              @default(0)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffAssignments  StaffServiceAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

// ─── Epic 6 — Staff Domain ────────────────────────────────────────────

enum StaffStatus {
  ACTIVE
  INACTIVE
}

model StaffProfile {
  id                  String            @id @default(uuid())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tenantId            String
  userId              String?           // optional link to User identity
  displayName         String
  email               String?
  phone               String?
  photoUrl            String?
  role                String            // free-text role title
  status              StaffStatus       @default(ACTIVE)
  isBookable          Boolean           @default(false)
  locationId          String?
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduleWindows     StaffScheduleWindow[]
  blackoutDates       StaffBlackoutDate[]
  serviceAssignments  StaffServiceAssignment[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, locationId])
}

model StaffScheduleWindow {
  id          String       @id @default(uuid())
  createdAt   DateTime     @default(now())
  staffId     String
  dayOfWeek   Int          // 0=Sunday … 6=Saturday
  startTime   String       // "HH:mm" 24h format
  endTime     String       // "HH:mm" 24h format
  staff       StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, dayOfWeek])
}

model StaffBlackoutDate {
  id        String       @id @default(uuid())
  createdAt DateTime     @default(now())
  staffId   String
  date      DateTime     @db.Date
  reason    String?
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, date])
}

model StaffServiceAssignment {
  id        String       @id @default(uuid())
  createdAt DateTime     @default(now())
  staffId   String
  serviceId String
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

// ─── Epic 6 — Content & SEO Domain ────────────────────────────────────

enum ContentPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementPlacement {
  BANNER
  POPUP
  INLINE
}

model ContentPage {
  id           String            @id @default(uuid())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenantId     String
  title        String
  slug         String
  body         Json              // structured block-based content
  status       ContentPageStatus @default(DRAFT)
  seoTitle     String?
  seoDescription String?
  ogImageUrl   String?
  templateRegion String?         // e.g. "hero", "about", "services"
  sortOrder    Int               @default(0)
  publishedAt  DateTime?
  archivedAt   DateTime?
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, templateRegion])
}

model Announcement {
  id            String                @id @default(uuid())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  tenantId      String
  title         String
  body          String
  placement     AnnouncementPlacement @default(BANNER)
  isActive      Boolean               @default(true)
  startDate     DateTime?
  endDate       DateTime?
  displayPriority Int                 @default(0)
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([tenantId, placement])
  @@index([tenantId, startDate, endDate])
}

// ─── Epic 7 — Cart Domain ─────────────────────────────────────────────

enum FulfillmentMode {
  DELIVERY
  PICKUP
}

model CartSession {
  id                   String         @id @default(uuid())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  tenantId             String
  customerId           String?
  fulfillmentMode      FulfillmentMode @default(PICKUP)
  deliveryAddressLine1 String?
  deliveryAddressLine2 String?
  deliveryCity         String?
  deliveryState        String?
  deliveryZip          String?
  orderNotes           String?
  promoCode            String?
  loyaltyCode          String?
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items                CartItem[]

  @@index([tenantId, customerId])
}

model CartItem {
  id              String         @id @default(uuid())
  sessionId       String
  catalogItemId   String
  catalogItemName String
  variantId       String?
  variantName     String?
  quantity        Int
  addedPriceCents Int            // price at the time item was added (cents)
  session         CartSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  modifiers       CartModifier[]

  @@index([sessionId])
}

model CartModifier {
  id               String   @id @default(uuid())
  cartItemId       String
  modifierOptionId String
  modifierName     String
  priceCents       Int      // modifier price at the time it was added (cents)
  cartItem         CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)

  @@index([cartItemId])
}

// ─── Epic 6 — Vertical Template Defaults ──────────────────────────────

enum BusinessVertical {
  RESTAURANT
  RETAIL
  APPOINTMENT
  CONTRACTOR
}
