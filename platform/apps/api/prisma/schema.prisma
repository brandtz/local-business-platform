generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActorType {
  PLATFORM
  TENANT
  CUSTOMER
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PlatformRole {
  OWNER
  ADMIN
  SUPPORT
  ANALYST
}

enum TenantStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum CustomDomainVerificationState {
  PENDING
  VERIFIED
  FAILED
  DENIED
}

enum CustomDomainPromotionState {
  NOT_REQUESTED
  READY
  PROMOTED
  FAILED
  ROLLBACK_PENDING
  ROLLED_BACK
  DENIED
}

enum CredentialKind {
  PASSWORD
}

enum SessionScope {
  PLATFORM
  TENANT
  CUSTOMER
}

model User {
  id                String               @id @default(uuid())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  email             String               @unique
  normalizedEmail   String               @unique
  displayName       String?
  actorType         ActorType
  status            UserStatus           @default(INVITED)
  platformRole      PlatformRole?
  isEmailVerified   Boolean              @default(false)
  lastAuthenticatedAt DateTime?
  passwordCredential PasswordCredential?
  sessions          AuthSession[]
  memberships       TenantMembership[]

  @@index([actorType, status])
}

model Tenant {
  id               String             @id @default(uuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  displayName      String
  slug             String             @unique
  status           TenantStatus       @default(DRAFT)
  previewSubdomain String             @unique
  customDomainRecords TenantCustomDomain[]
  memberships      TenantMembership[]
  catalogCategories CatalogCategory[]
  catalogItems     CatalogItem[]
  services         Service[]
  staffProfiles    StaffProfile[]
  contentPages     ContentPage[]
  announcements    Announcement[]
  cartSessions     CartSession[]
  orders           Order[]
  bookings         Booking[]
  paymentConnections PaymentConnection[]
  portfolioProjects  PortfolioProject[]
  analyticsAggregations AnalyticsAggregation[]
  loyaltyProgramConfig  LoyaltyProgramConfig?
  customerLoyaltyAccounts CustomerLoyaltyAccount[]
}

model TenantCustomDomain {
  id                         String                        @id @default(uuid())
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt
  tenantId                   String
  hostname                   String
  verificationState          CustomDomainVerificationState @default(PENDING)
  verificationStateChangedAt DateTime?
  verificationFailureReason  String?
  verificationEvidence       Json?
  promotionState             CustomDomainPromotionState    @default(NOT_REQUESTED)
  promotionStateChangedAt    DateTime?
  promotionFailureReason     String?
  promotedAt                 DateTime?
  rollbackCompletedAt        DateTime?
  tenant                     Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, hostname])
  @@index([hostname])
  @@index([tenantId, verificationState])
  @@index([tenantId, promotionState])
}

model TenantMembership {
  id          String     @id @default(uuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenantId    String
  userId      String
  role        TenantRole
  isPrimary   Boolean    @default(false)
  joinedAt    DateTime   @default(now())
  revokedAt   DateTime?
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, role])
  @@index([tenantId, role])
}

model PasswordCredential {
  id                String         @id @default(uuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  userId            String         @unique
  kind              CredentialKind @default(PASSWORD)
  passwordHash      String
  hashAlgorithm     String
  passwordVersion   Int            @default(1)
  passwordChangedAt DateTime       @default(now())
  mustRotate        Boolean        @default(false)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id                String       @id @default(uuid())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  userId            String
  actorType         ActorType
  scope             SessionScope
  refreshTokenHash  String       @unique
  issuedAt          DateTime     @default(now())
  expiresAt         DateTime
  idleExpiresAt     DateTime
  lastSeenAt        DateTime?
  revokedAt         DateTime?
  revokeReason      String?
  ipAddress         String?
  userAgent         String?
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ─── Epic 6 — Catalog Domain ───────────────────────────────────────────

enum CatalogItemStatus {
  ACTIVE
  INACTIVE
}

enum CatalogItemVisibility {
  PUBLISHED
  DRAFT
}

model CatalogCategory {
  id          String        @id @default(uuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenantId    String
  name        String
  slug        String
  description String?
  imageUrl    String?
  sortOrder   Int           @default(0)
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       CatalogItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, sortOrder])
}

model CatalogItem {
  id              String                @id @default(uuid())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  tenantId        String
  categoryId      String
  name            String
  slug            String
  description     String?
  price           Int                   // cents
  compareAtPrice  Int?                  // cents — strike-through price
  status          CatalogItemStatus     @default(ACTIVE)
  visibility      CatalogItemVisibility @default(DRAFT)
  sortOrder       Int                   @default(0)
  stockQuantity   Int?
  lowStockThreshold Int?
  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        CatalogCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mediaGallery    CatalogItemMedia[]
  modifierGroups  ModifierGroup[]

  @@unique([tenantId, slug])
  @@index([tenantId, categoryId, sortOrder])
  @@index([tenantId, status, visibility])
}

model CatalogItemMedia {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now())
  itemId    String
  url       String
  altText   String?
  sortOrder Int         @default(0)
  item      CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
}

model ModifierGroup {
  id          String            @id @default(uuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenantId    String
  itemId      String
  name        String            // e.g. "Size", "Color", "Add-ons"
  selectionMode String          @default("single") // "single" | "multiple"
  isRequired  Boolean           @default(false)
  minSelections Int             @default(0)
  maxSelections Int?
  sortOrder   Int               @default(0)
  item        CatalogItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options     ModifierOption[]

  @@index([tenantId, itemId, sortOrder])
}

model ModifierOption {
  id           String        @id @default(uuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  groupId      String
  name         String
  priceAdjustment Int        @default(0) // cents, can be 0 or positive
  isDefault    Boolean       @default(false)
  sortOrder    Int           @default(0)
  group        ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, sortOrder])
}

// ─── Epic 6 — Service Domain ───────────────────────────────────────────

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

model Service {
  id                String           @id @default(uuid())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tenantId          String
  name              String
  slug              String
  description       String?
  durationMinutes   Int
  price             Int              // cents
  status            ServiceStatus    @default(ACTIVE)
  isBookable        Boolean          @default(true)
  bufferMinutes     Int              @default(0)
  maxAdvanceDays    Int              @default(60)
  minAdvanceHours   Int              @default(1)
  sortOrder         Int              @default(0)
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staffAssignments  StaffServiceAssignment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

// ─── Epic 6 — Staff Domain ────────────────────────────────────────────

enum StaffStatus {
  ACTIVE
  INACTIVE
}

model StaffProfile {
  id                  String            @id @default(uuid())
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  tenantId            String
  userId              String?           // optional link to User identity
  displayName         String
  email               String?
  phone               String?
  photoUrl            String?
  role                String            // free-text role title
  status              StaffStatus       @default(ACTIVE)
  isBookable          Boolean           @default(false)
  locationId          String?
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduleWindows     StaffScheduleWindow[]
  blackoutDates       StaffBlackoutDate[]
  serviceAssignments  StaffServiceAssignment[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, locationId])
}

model StaffScheduleWindow {
  id          String       @id @default(uuid())
  createdAt   DateTime     @default(now())
  staffId     String
  dayOfWeek   Int          // 0=Sunday … 6=Saturday
  startTime   String       // "HH:mm" 24h format
  endTime     String       // "HH:mm" 24h format
  staff       StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, dayOfWeek])
}

model StaffBlackoutDate {
  id        String       @id @default(uuid())
  createdAt DateTime     @default(now())
  staffId   String
  date      DateTime     @db.Date
  reason    String?
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, date])
}

model StaffServiceAssignment {
  id        String       @id @default(uuid())
  createdAt DateTime     @default(now())
  staffId   String
  serviceId String
  staff     StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

// ─── Epic 6 — Content & SEO Domain ────────────────────────────────────

enum ContentPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementPlacement {
  BANNER
  POPUP
  INLINE
}

model ContentPage {
  id           String            @id @default(uuid())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tenantId     String
  title        String
  slug         String
  body         Json              // structured block-based content
  status       ContentPageStatus @default(DRAFT)
  seoTitle     String?
  seoDescription String?
  ogImageUrl   String?
  templateRegion String?         // e.g. "hero", "about", "services"
  sortOrder    Int               @default(0)
  publishedAt  DateTime?
  archivedAt   DateTime?
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, templateRegion])
}

model Announcement {
  id            String                @id @default(uuid())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  tenantId      String
  title         String
  body          String
  placement     AnnouncementPlacement @default(BANNER)
  isActive      Boolean               @default(true)
  startDate     DateTime?
  endDate       DateTime?
  displayPriority Int                 @default(0)
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([tenantId, placement])
  @@index([tenantId, startDate, endDate])
}

// ─── Epic 7 — Cart Domain ─────────────────────────────────────────────

enum FulfillmentMode {
  DELIVERY
  PICKUP
}

model CartSession {
  id                   String         @id @default(uuid())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  tenantId             String
  customerId           String?
  fulfillmentMode      FulfillmentMode @default(PICKUP)
  deliveryAddressLine1 String?
  deliveryAddressLine2 String?
  deliveryCity         String?
  deliveryState        String?
  deliveryZip          String?
  orderNotes           String?
  promoCode            String?
  loyaltyCode          String?
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items                CartItem[]

  @@index([tenantId, customerId])
}

model CartItem {
  id              String         @id @default(uuid())
  sessionId       String
  catalogItemId   String
  catalogItemName String
  variantId       String?
  variantName     String?
  quantity        Int
  addedPriceCents Int            // price at the time item was added (cents)
  session         CartSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  modifiers       CartModifier[]

  @@index([sessionId])
}

model CartModifier {
  id               String   @id @default(uuid())
  cartItemId       String
  modifierOptionId String
  modifierName     String
  priceCents       Int      // modifier price at the time it was added (cents)
  cartItem         CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)

  @@index([cartItemId])
}

// ─── Epic 7 — Order Domain ────────────────────────────────────────────

enum OrderStatus {
  DRAFT
  PLACED
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderFulfillmentMode {
  DELIVERY
  PICKUP
  DINE_IN
}

model Order {
  id                   String              @id @default(uuid())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  tenantId             String
  customerId           String?
  customerName         String?
  customerEmail        String?
  customerPhone        String?
  status               OrderStatus         @default(DRAFT)
  fulfillmentMode      OrderFulfillmentMode @default(PICKUP)
  deliveryAddressLine1 String?
  deliveryAddressLine2 String?
  deliveryCity         String?
  deliveryState        String?
  deliveryZip          String?
  orderNotes           String?
  subtotalCents        Int
  discountCents        Int                 @default(0)
  taxCents             Int                 @default(0)
  tipCents             Int                 @default(0)
  deliveryFeeCents     Int                 @default(0)
  totalCents           Int
  promoCode            String?
  loyaltyCode          String?
  cartSessionId        String?
  placedAt             DateTime?
  confirmedAt          DateTime?
  preparingAt          DateTime?
  readyAt              DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items                OrderItem[]

  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
}

model OrderItem {
  id              String              @id @default(uuid())
  orderId         String
  catalogItemId   String
  catalogItemName String
  variantId       String?
  variantName     String?
  quantity        Int
  unitPriceCents  Int
  lineTotalCents  Int
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  modifiers       OrderItemModifier[]

  @@index([orderId])
}

model OrderItemModifier {
  id               String    @id @default(uuid())
  orderItemId      String
  modifierOptionId String
  modifierName     String
  priceCents       Int
  orderItem        OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

// ─── Epic 7 — Booking Domain ──────────────────────────────────────────

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Booking {
  id                String        @id @default(uuid())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  tenantId          String
  customerId        String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  serviceId         String
  serviceName       String
  staffId           String
  staffName         String
  locationId        String
  startTime         DateTime
  endTime           DateTime
  durationMinutes   Int
  status            BookingStatus @default(REQUESTED)
  notes             String?
  cancellationReason String?
  requestedAt       DateTime?
  confirmedAt       DateTime?
  checkedInAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  noShowAt          DateTime?
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Double-booking prevention: no two active bookings for the same staff at the same time
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, staffId, startTime, endTime])
  @@index([tenantId, startTime])
  @@index([tenantId, serviceId])
}

// ─── Epic 8 — Payment Connection Domain ───────────────────────────────

enum PaymentProvider {
  STRIPE
  SQUARE
}

enum PaymentConnectionStatus {
  INACTIVE
  VERIFYING
  ACTIVE
  SUSPENDED
}

model PaymentConnection {
  id                  String                  @id @default(uuid())
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  tenantId            String
  provider            PaymentProvider
  displayName         String
  status              PaymentConnectionStatus @default(INACTIVE)
  mode                String                  @default("sandbox") // "sandbox" | "production"
  encryptedCredentials String                 // AES-256-GCM encrypted JSON
  credentialsIv       String                  // Initialization vector for decryption
  credentialsTag      String                  // Auth tag for GCM integrity
  lastVerifiedAt      DateTime?
  verificationError   String?
  statusChangedAt     DateTime?
  suspendedReason     String?
  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId, status])
  @@index([tenantId, provider, status])
}

// ─── Epic 8 — Notification Delivery Domain ────────────────────────────

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum DeliveryStatus {
  PENDING
  QUEUED
  SENDING
  DELIVERED
  FAILED
  BOUNCED
  DEAD_LETTER
}

model NotificationTemplate {
  id               String              @id @default(uuid())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenantId         String?             // null = shared/default template
  eventType        String              // e.g. "order.confirmed"
  channel          NotificationChannel
  subjectTemplate  String
  bodyTemplate     String
  isCustomizable   Boolean             @default(true)
  isActive         Boolean             @default(true)

  @@unique([tenantId, eventType, channel])
  @@index([eventType, channel])
}

model NotificationDelivery {
  id                    String              @id @default(uuid())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  tenantId              String
  notificationEventId   String
  channel               NotificationChannel
  recipientAddress      String
  renderedSubject       String
  renderedBody          String              @db.Text
  status                DeliveryStatus      @default(PENDING)
  attemptCount          Int                 @default(0)
  maxAttempts           Int                 @default(3)
  failureCategory       String?
  failureReason         String?
  providerName          String?
  providerMessageId     String?
  idempotencyKey        String              @unique
  lastAttemptAt         DateTime?
  deliveredAt           DateTime?

  @@index([tenantId, status])
  @@index([tenantId, channel, status])
  @@index([tenantId, createdAt])
  @@index([notificationEventId])
}

model InAppNotification {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  tenantId     String
  recipientId  String
  eventType    String
  title        String
  body         String
  entityType   String?
  entityId     String?
  isRead       Boolean  @default(false)
  readAt       DateTime?

  @@index([tenantId, recipientId, isRead])
  @@index([tenantId, recipientId, createdAt])
}

// ─── Epic 6 — Vertical Template Defaults ──────────────────────────────

enum BusinessVertical {
  RESTAURANT
  RETAIL
  APPOINTMENT
  CONTRACTOR
}

// ─── Epic 12 — Subscription Package and Tier Model (E12-S1) ──────────

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionPackageStatus {
  ACTIVE
  DEPRECATED
}

enum UsageLimitType {
  ORDERS_PER_MONTH
  STORAGE_GB
  STAFF_SEATS
}

enum UsageLimitResetPeriod {
  MONTHLY
  ANNUAL
  NONE
}

model SubscriptionPackage {
  id               String                    @id @default(uuid())
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  name             String                    @unique
  description      String?
  billingInterval  BillingInterval
  basePriceCents   Int
  trialDurationDays Int?
  status           SubscriptionPackageStatus @default(ACTIVE)
  deprecatedAt     DateTime?
  displayOrder     Int                       @default(0)
  entitlements     PackageEntitlement[]
  usageLimits      PackageUsageLimit[]
  premiumFeatures  PackagePremiumFeature[]
  versions         PackageVersion[]

  @@index([status])
  @@index([billingInterval])
  @@index([displayOrder])
}

model PackageEntitlement {
  id         String             @id @default(uuid())
  createdAt  DateTime           @default(now())
  packageId  String
  package    SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  moduleKey  String
  enabled    Boolean            @default(true)

  @@unique([packageId, moduleKey])
  @@index([packageId])
}

model PackageUsageLimit {
  id          String              @id @default(uuid())
  createdAt   DateTime            @default(now())
  packageId   String
  package     SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  limitType   UsageLimitType
  softLimit   Int?
  hardLimit   Int
  resetPeriod UsageLimitResetPeriod @default(MONTHLY)

  @@unique([packageId, limitType])
  @@index([packageId])
}

model PackagePremiumFeature {
  id          String              @id @default(uuid())
  createdAt   DateTime            @default(now())
  packageId   String
  package     SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  featureFlag String

  @@unique([packageId, featureFlag])
  @@index([packageId])
}

model PackageVersion {
  id                   String              @id @default(uuid())
  createdAt            DateTime            @default(now())
  packageId            String
  package              SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  versionNumber        Int
  changeReason         String?
  changedBy            String
  changedAt            DateTime            @default(now())
  entitlementsSnapshot Json

  @@unique([packageId, versionNumber])
  @@index([packageId])
}

// ─── Epic 11 — Portfolio & Showcase Module (E11-S5) ───────────────────

enum PortfolioProjectStatus {
  DRAFT
  PUBLISHED
}

enum PortfolioMediaTag {
  BEFORE
  AFTER
  GENERAL
}

model PortfolioProject {
  id                     String                 @id @default(uuid())
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  tenantId               String
  title                  String
  description            Json                   // rich text JSON
  projectDate            DateTime?
  location               String?
  serviceCategories      String[]               @default([])
  status                 PortfolioProjectStatus  @default(DRAFT)
  sortOrder              Int                    @default(0)
  isFeatured             Boolean                @default(false)
  testimonialQuote       String?
  testimonialAttribution String?
  testimonialRating      Int?
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  media                  PortfolioProjectMedia[]

  @@index([tenantId, status])
  @@index([tenantId, sortOrder])
  @@index([tenantId, isFeatured])
}

model PortfolioProjectMedia {
  id        String            @id @default(uuid())
  createdAt DateTime          @default(now())
  projectId String
  url       String
  altText   String?
  caption   String?
  tag       PortfolioMediaTag @default(GENERAL)
  sortOrder Int               @default(0)
  project   PortfolioProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

// ─── Epic 9 — Import Artifact Intake and Job Orchestration (E9-S2) ────

enum ImportArtifactType {
  MENU_PDF
  MENU_IMAGE
  SERVICE_LIST_CSV
  CATALOG_SPREADSHEET
  BROCHURE_IMAGE
  PRICE_SHEET_PDF
}

enum ArtifactUploadStatus {
  PENDING
  SCANNING
  STORED
  SCAN_FAILED
  REJECTED
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  STAGED
  FAILED
  COMPLETED
}

model ImportArtifact {
  id                String              @id @default(uuid())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tenantId          String
  artifactType      ImportArtifactType
  originalFilename  String
  sanitizedFilename String
  storagePath       String
  mimeType          String
  fileSizeBytes     Int
  uploadStatus      ArtifactUploadStatus @default(PENDING)
  scanResult        String?
  uploadedBy        String
  importJobs        ImportJob[]

  @@index([tenantId])
  @@index([tenantId, artifactType])
  @@index([tenantId, uploadStatus])
}

model ImportJob {
  id             String          @id @default(uuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenantId       String
  artifactId     String
  artifact       ImportArtifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  status         ImportJobStatus @default(PENDING)
  retryCount     Int             @default(0)
  maxRetries     Int             @default(3)
  failureReason  String?
  stagedOutput   Json?
  createdBy      String
  startedAt      DateTime?
  completedAt    DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([artifactId])
}

// ─── Epic 11 — Business Analytics & Reporting ─────────────────────────────

enum AnalyticsAggregationPeriodEnum {
  DAILY
  WEEKLY
  MONTHLY
}

enum AggregationJobStatusEnum {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model AnalyticsAggregation {
  id                    String                         @id @default(uuid())
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  tenantId              String
  locationId            String?
  periodType            AnalyticsAggregationPeriodEnum
  periodStart           DateTime
  periodEnd             DateTime
  revenueCents          Int                            @default(0)
  orderCount            Int                            @default(0)
  bookingCount          Int                            @default(0)
  newCustomerCount      Int                            @default(0)
  returningCustomerCount Int                           @default(0)
  channelBreakdown      Json                           @default("{}")
  tenant                Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, locationId, periodType, periodStart])
  @@index([tenantId, periodType, periodStart])
  @@index([tenantId, locationId, periodType])
}

model AggregationJob {
  id             String                         @id @default(uuid())
  createdAt      DateTime                       @default(now())
  tenantId       String
  periodType     AnalyticsAggregationPeriodEnum
  periodStart    DateTime
  periodEnd      DateTime
  status         AggregationJobStatusEnum       @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  failureReason  String?

  @@index([tenantId, status])
  @@index([tenantId, periodType, periodStart])
}

// ---------------------------------------------------------------------------
// E11-S2: Customer Loyalty and Rewards Program
// ---------------------------------------------------------------------------

enum PointAccumulationModeEnum {
  PER_DOLLAR
  PER_ORDER
}

enum PointExpirationPolicyEnum {
  TIME_BASED
  ROLLING
  NEVER
}

enum LedgerEntryTypeEnum {
  EARN
  REDEEM
  EXPIRE
  ADJUST
}

model LoyaltyProgramConfig {
  id                      String                    @id @default(uuid())
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  tenantId                String                    @unique
  enabled                 Boolean                   @default(false)
  tiers                   Json                      @default("[]")
  accumulationMode        PointAccumulationModeEnum  @default(PER_DOLLAR)
  pointsPerDollar         Int                       @default(1)
  pointsPerOrder          Int                       @default(10)
  pointRedemptionRate     Int                       @default(100)
  minimumRedemptionPoints Int                       @default(100)
  expirationPolicy        PointExpirationPolicyEnum @default(ROLLING)
  expirationDays          Int                       @default(365)
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CustomerLoyaltyAccount {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenantId       String
  customerId     String
  currentTier    String           @default("bronze")
  pointBalance   Int              @default(0)
  lifetimePoints Int              @default(0)
  memberSince    DateTime         @default(now())
  ledgerEntries  PointLedgerEntry[]
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId])
  @@index([tenantId, currentTier])
  @@index([tenantId, pointBalance])
}

model PointLedgerEntry {
  id             String               @id @default(uuid())
  createdAt      DateTime             @default(now())
  tenantId       String
  customerId     String
  accountId      String
  type           LedgerEntryTypeEnum
  points         Int
  balanceAfter   Int
  description    String
  referenceType  String?
  referenceId    String?
  expiresAt      DateTime?
  account        CustomerLoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId, createdAt])
  @@index([tenantId, customerId, type])
  @@index([expiresAt])
}
