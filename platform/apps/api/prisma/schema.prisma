generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActorType {
  PLATFORM
  TENANT
  CUSTOMER
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PlatformRole {
  OWNER
  ADMIN
  SUPPORT
  ANALYST
}

enum TenantStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
}

enum CustomDomainVerificationState {
  PENDING
  VERIFIED
  FAILED
  DENIED
}

enum CustomDomainPromotionState {
  NOT_REQUESTED
  READY
  PROMOTED
  FAILED
  ROLLBACK_PENDING
  ROLLED_BACK
  DENIED
}

enum CredentialKind {
  PASSWORD
}

enum SessionScope {
  PLATFORM
  TENANT
  CUSTOMER
}

model User {
  id                String               @id @default(uuid())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  email             String               @unique
  normalizedEmail   String               @unique
  displayName       String?
  actorType         ActorType
  status            UserStatus           @default(INVITED)
  platformRole      PlatformRole?
  isEmailVerified   Boolean              @default(false)
  lastAuthenticatedAt DateTime?
  passwordCredential PasswordCredential?
  sessions          AuthSession[]
  memberships       TenantMembership[]

  @@index([actorType, status])
}

model Tenant {
  id               String             @id @default(uuid())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  displayName      String
  slug             String             @unique
  status           TenantStatus       @default(DRAFT)
  previewSubdomain String             @unique
  customDomainRecords TenantCustomDomain[]
  memberships      TenantMembership[]
  categories       CatalogCategory[]
  items            CatalogItem[]
  itemVariants     CatalogItemVariant[]
  itemModifiers    CatalogItemModifier[]
  mediaReferences  CatalogMediaReference[]
}

model TenantCustomDomain {
  id                         String                        @id @default(uuid())
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt
  tenantId                   String
  hostname                   String
  verificationState          CustomDomainVerificationState @default(PENDING)
  verificationStateChangedAt DateTime?
  verificationFailureReason  String?
  verificationEvidence       Json?
  promotionState             CustomDomainPromotionState    @default(NOT_REQUESTED)
  promotionStateChangedAt    DateTime?
  promotionFailureReason     String?
  promotedAt                 DateTime?
  rollbackCompletedAt        DateTime?
  tenant                     Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, hostname])
  @@index([hostname])
  @@index([tenantId, verificationState])
  @@index([tenantId, promotionState])
}

model TenantMembership {
  id          String     @id @default(uuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenantId    String
  userId      String
  role        TenantRole
  isPrimary   Boolean    @default(false)
  joinedAt    DateTime   @default(now())
  revokedAt   DateTime?
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, role])
  @@index([tenantId, role])
}

model PasswordCredential {
  id                String         @id @default(uuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  userId            String         @unique
  kind              CredentialKind @default(PASSWORD)
  passwordHash      String
  hashAlgorithm     String
  passwordVersion   Int            @default(1)
  passwordChangedAt DateTime       @default(now())
  mustRotate        Boolean        @default(false)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id                String       @id @default(uuid())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  userId            String
  actorType         ActorType
  scope             SessionScope
  refreshTokenHash  String       @unique
  issuedAt          DateTime     @default(now())
  expiresAt         DateTime
  idleExpiresAt     DateTime
  lastSeenAt        DateTime?
  revokedAt         DateTime?
  revokeReason      String?
  ipAddress         String?
  userAgent         String?
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ---------------------------------------------------------------------------
// Catalog domain models
// ---------------------------------------------------------------------------

enum CatalogItemStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CatalogCategoryStatus {
  ACTIVE
  ARCHIVED
}

model CatalogCategory {
  id               String                @id @default(uuid())
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  tenantId         String
  name             String
  slug             String
  description      String?
  displayOrder     Int                   @default(0)
  status           CatalogCategoryStatus @default(ACTIVE)
  parentCategoryId String?
  imageUrl         String?
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentCategory   CatalogCategory?      @relation("CategoryParent", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories  CatalogCategory[]     @relation("CategoryParent")
  items            CatalogItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, displayOrder])
}

model CatalogItem {
  id             String            @id @default(uuid())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  tenantId       String
  categoryId     String
  name           String
  slug           String
  description    String?
  status         CatalogItemStatus @default(DRAFT)
  displayOrder   Int               @default(0)
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       CatalogCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants       CatalogItemVariant[]
  modifiers      CatalogItemModifier[]
  mediaReferences CatalogMediaReference[]

  @@unique([tenantId, slug])
  @@index([tenantId, categoryId, status])
  @@index([tenantId, status])
  @@index([tenantId, displayOrder])
}

model CatalogItemVariant {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String
  itemId       String
  name         String
  priceCents   Int
  isDefault    Boolean  @default(false)
  displayOrder Int      @default(0)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item         CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([tenantId, itemId])
}

model CatalogItemModifier {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String
  itemId       String
  name         String
  priceCents   Int      @default(0)
  isRequired   Boolean  @default(false)
  displayOrder Int      @default(0)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item         CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([tenantId, itemId])
}

model CatalogMediaReference {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String
  itemId       String
  url          String
  altText      String?
  displayOrder Int      @default(0)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item         CatalogItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([tenantId, itemId])
}
